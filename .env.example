# ── Database ──────────────────────────────────────────────────────────────────
# Neon free tier: create project at https://neon.tech, copy the connection string
# Format: postgresql://user:password@ep-xxxx.region.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=postgresql://user:password@ep-xxxx.us-east-2.aws.neon.tech/vendex?sslmode=require

# ── AI (Gemini) ───────────────────────────────────────────────────────────────
# Get free key from https://aistudio.google.com → Get API Key
# Free tier: 1500 requests/day, no credit card needed.
# Used only for the Compare Insights feature.
GEMINI_API_KEY=AIzaSy-xxxxxxxxxxxxxxxxxxxx

# ── Frontend → Backend ────────────────────────────────────────────────────────
NEXT_PUBLIC_BACKEND_URL=http://localhost:3002

# ── Webhooks (optional) ───────────────────────────────────────────────────────
NEXTJS_WEBHOOK_URL=http://localhost:3001/api/webhooks/job-update
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
NEXTJS_WEBHOOK_SECRET=change-me-to-a-random-secret

# ── Security (production only) ────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins for CORS
# CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
# Set to "production" to enable HSTS and disable /docs
# ENVIRONMENT=production
